# Default application environment
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SECRET_KEY=YOUR_SUPABASE_SECRET_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_PROJECT_REF=YOUR_SUPABASE_PROJECT_REF
SUPABASE_DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD

# Explicit production aliases for migration and verification tooling
SUPABASE_URL_PROD=YOUR_PRODUCTION_SUPABASE_URL
SUPABASE_PUBLISHABLE_KEY_PROD=YOUR_PRODUCTION_SUPABASE_PUBLISHABLE_KEY
SUPABASE_ANON_KEY_PROD=YOUR_PRODUCTION_SUPABASE_ANON_KEY
SUPABASE_SECRET_KEY_PROD=YOUR_PRODUCTION_SUPABASE_SECRET_KEY
SUPABASE_SERVICE_ROLE_KEY_PROD=YOUR_PRODUCTION_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_PROJECT_REF_PROD=YOUR_PRODUCTION_SUPABASE_PROJECT_REF
SUPABASE_DB_PASSWORD_PROD=YOUR_PRODUCTION_SUPABASE_DB_PASSWORD

# Current production email adapter and portal links
RESEND_API_KEY=YOUR_RESEND_API_KEY
RESEND_FROM=YOUR_RESEND_FROM_ADDRESS
PORTAL_BASE_URL=YOUR_PORTAL_BASE_URL

# GitHub App registry connection (server-only; never use a personal access token)
PORTAL_GITHUB_APP_ID=YOUR_GITHUB_APP_ID
PORTAL_GITHUB_APP_INSTALLATION_ID=YOUR_GITHUB_APP_INSTALLATION_ID
PORTAL_GITHUB_APP_PRIVATE_KEY=YOUR_BASE64_OR_NEWLINE_ESCAPED_PRIVATE_KEY

# E2E test credentials (a seeded portal admin on the DEVELOPMENT project;
# required only for `npx playwright test`)
PORTAL_SEED_ADMIN_EMAIL=YOUR_TEST_ADMIN_EMAIL
PORTAL_SEED_ADMIN_PASSWORD=YOUR_TEST_ADMIN_PASSWORD
